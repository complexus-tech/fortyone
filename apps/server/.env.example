# Database
APP_DB_HOST=127.0.0.1
APP_DB_PORT=5432
APP_DB_USER=postgres
APP_DB_PASSWORD=postgres
APP_DB_NAME=fortyone
APP_DB_MAX_OPEN_CONNS=25
APP_DB_MAX_IDLE_CONNS=25
APP_DB_DISABLE_TLS=true

# Google (legacy fallback, use APP_AUTH_GOOGLE_CLIENT_IDS instead)
GOOGLE_CLIENT_ID=
# Auth
APP_AUTH_SECRET_KEY=
APP_AUTH_COOKIE_DOMAIN=
APP_AUTH_GOOGLE_CLIENT_IDS=
APP_AUTH_GOOGLE_CLIENT_SECRET=
APP_AUTH_GOOGLE_REDIRECT_URL=
# Open ai
OPENAI_API_KEY=
# Redis
APP_REDIS_HOST=127.0.0.1
APP_REDIS_PORT=6379
APP_REDIS_PASSWORD=
APP_REDIS_DB=0
APP_REDIS_DISABLE_TLS=true
# APP
APP_API_HOST=0.0.0.0:8000
APP_API_READ_TIMEOUT=120s
APP_API_WRITE_TIMEOUT=15s
APP_API_IDLE_TIMEOUT=60s
APP_API_SHUTDOWN_TIMEOUT=30s
APP_WEBSITE_URL=http://localhost:3000
APP_TRACING_ENDPOINT=http://localhost:4318
# Storage Provider
APP_STORAGE_PROVIDER=aws

# Azure Storage
APP_AZURE_STORAGE_ACCOUNT_KEY=
APP_AZURE_STORAGE_CONNECTION_STRING=
APP_AZURE_STORAGE_ACCOUNT_NAME=

# AWS S3 Storage
APP_AWS_ACCESS_KEY_ID=
APP_AWS_SECRET_ACCESS_KEY=
APP_AWS_REGION=
APP_AWS_ENDPOINT=
APP_AWS_PUBLIC_URL=
APP_AWS_FORCE_PATH_STYLE=
# GitHub Integration
APP_GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_PRIVATE_KEY_PATH=keys/github.pem
GITHUB_REDIRECT_URL=
GITHUB_WEBHOOK_URL=
